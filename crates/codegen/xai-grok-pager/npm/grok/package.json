{
    "name": "@gork-build/gork",
    "version": "0.1.220-alpha.4",
    "description": "Gork Build \u2014 community VSCodium-style Grok Build (no vendor telemetry)",
    "license": "Apache-2.0",
    "bin": {
        "gork": "bin/grok",
        "grok": "bin/grok"
    },
    "files": [
        "bin/"
    ],
    "os": [
        "darwin",
        "linux",
        "win32"
    ],
    "cpu": [
        "arm64",
        "x64"
    ],
    "scripts": {
        "postinstall": "node bin/postinstall.js"
    },
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "@iarna/toml": "^3.0.0"
    },
    "optionalDependencies": {
        "@gork-build/gork-darwin-arm64": "0.1.220-alpha.4",
        "@gork-build/gork-darwin-x64": "0.1.220-alpha.4",
        "@gork-build/gork-linux-arm64": "0.1.220-alpha.4",
        "@gork-build/gork-linux-x64": "0.1.220-alpha.4",
        "@gork-build/gork-win32-arm64": "0.1.220-alpha.4",
        "@gork-build/gork-win32-x64": "0.1.220-alpha.4"
    }
}
